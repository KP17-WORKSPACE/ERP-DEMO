            $edit = SysCrmLeads::where('id',$id)->first();
            

            $comments = SysCrmLeadsComments::where('lead_id',$id)->orderBy('id','DESC')->get();

            return view('backEnd.crm.LeadView', compact('currency', 'company','staff','edit','leads','comments'));
