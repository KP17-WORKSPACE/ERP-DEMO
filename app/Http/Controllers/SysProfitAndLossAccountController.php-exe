    public static function get_net_profit_loss($from_date,$to_date)
    {
        $com_ids = SysHelper::get_company_access();
        $gross_profit=0;
        $gross_loss=0;

        $net_profit=0;
        $net_loss=0;

        $indirect_expenses=0;
        $indirect_income=0;

        $ie_acc_id = SysChartofAccounts::select('id','account_name')->where('subgroup',14)->wherein('company_id',$com_ids)->where('status',1)->get();
        $indirect_expenses = SysProfitAndLossAccountController::get_indirect_expenses($from_date,$to_date,$ie_acc_id);
        
        $ii_acc_id = SysChartofAccounts::select('id','account_name')->where('subgroup',16)->wherein('company_id',$com_ids)->where('status',1)->get();
        $indirect_income = SysProfitAndLossAccountController::get_indirect_income($from_date,$to_date,$ii_acc_id);
        $ie_acc_id = SysChartofAccounts::select('id','account_name')->where('subgroup',13)->wherein('company_id',$com_ids)->where('status',1)->get();
        $direct_expenses = SysProfitAndLossAccountController::get_direct_expenses($from_date,$to_date,$ie_acc_id);
        $opening_stock = SysProfitAndLossAccountController::get_opening_stock($from_date,$to_date,$com_ids);
        $purchase = SysProfitAndLossAccountController::get_purchase($from_date,$to_date,$com_ids);
        $purchase_return = SysProfitAndLossAccountController::get_purchase_return($from_date,$to_date,$com_ids);
        
        $ie_acc_id = SysChartofAccounts::select('id','account_name')->where('subgroup',15)->wherein('company_id',$com_ids)->where('status',1)->get();
        $direct_incomes = SysProfitAndLossAccountController::get_direct_income($from_date,$to_date,$ie_acc_id);                
        $closing_stock = SysProfitAndLossAccountController::get_closing_stock($from_date,$to_date,$com_ids);                
        $sales = SysProfitAndLossAccountController::get_sales($from_date,$to_date,$com_ids);
        $sales_return = SysProfitAndLossAccountController::get_sales_return($from_date,$to_date,$com_ids);
        
        $total_direct_expences = ($direct_expenses + $opening_stock + abs($purchase - $purchase_return));
        $total_direct_incomes = ($direct_incomes + $closing_stock + abs($sales - $sales_return));
        
        //Direct Income - Direct Expence = Gross Profit
        if($total_direct_expences > $total_direct_incomes) {
            $gross_loss = $total_direct_expences - $total_direct_incomes;
        }
        else {
            $gross_profit = $total_direct_incomes - $total_direct_expences;
        }
        
        //(Indirect income + Gross Profit) - Indirect Expence = Net Profit
        if($gross_profit > $gross_loss) {
            if($indirect_expenses > ($indirect_income + $gross_profit)){
                $net_loss = $indirect_expenses - abs($indirect_income + $gross_profit);
            } else {
                $net_profit = ($indirect_income + $gross_profit) - $indirect_expenses;
            }
        } else {
            if($indirect_expenses > ($indirect_income - $gross_loss)){
                $net_loss = $indirect_expenses - abs($indirect_income - $gross_loss);
            } else {
                $net_profit = abs($indirect_income - $gross_loss) - $indirect_expenses;
            }
        }
        return ['net-profit' => $net_profit, 'net-loss' => $net_loss];        
    }
}