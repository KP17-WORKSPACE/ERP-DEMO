    public static function get_opening_stock($from_date,$to_date,$company_id)
    {
        try {
            $opening_stock_account_id = SysChartofAccounts::select('id')->where('account_name','Opening Stock')->pluck('id');
            $trn = SysChartofAccountsTransaction::select(DB::raw('SUM(debit_amount) - SUM(credit_amount) as amount'))
            ->whereRaw("DATE_FORMAT(created_at, '%Y-%m-%d') < '".$from_date."'")
            ->wherein('account_id',$opening_stock_account_id)
            ->wherein('company_id',$company_id)->first();
            if($trn->amount==""){
                return '0.00';
            }
            return $trn->amount;

            $tot=0;
            //Debit - credit = balance

            if(count($trn)>0){
                foreach($trn as $dt){
                    if($dt->qty_in > 0)
                    $tot += $dt->price_in;
                }
                return number_format($tot, 2, '.', '');
            } else{
                return number_format($tot, 2, '.', '');
            }        
        } catch (\Throwable $th) {
            return $th;
        }
    }
    public static function get_closing_stock($from_date,$to_date,$company_id)
    {
        try {
            $opening_stock_account_id = SysChartofAccounts::select('id')->where('account_name','Opening Stock')->pluck('id');
            $trn = SysChartofAccountsTransaction::select(DB::raw('SUM(debit_amount) - SUM(credit_amount) as amount'))
            ->whereRaw("DATE_FORMAT(created_at, '%Y-%m-%d') <= '".$to_date."'")
            ->wherein('account_id',$opening_stock_account_id)
            ->wherein('company_id',$company_id)->first();
            if($trn->amount==""){
                return '0.00';
            }
            return $trn->amount;

            $tot=0;
            $trn = SysItemStock::whereRaw("DATE_FORMAT(created_at, '%Y-%m-%d') <= '".$to_date."'")->wherein('sys_item_stock.company_id',$company_id)->get();
            if(count($trn)>0){
                foreach($trn as $dt){
                    if($dt->qty_in > 0)
                    $tot += $dt->price_in;
                }
                return number_format($tot, 2, '.', '');
            } else{
                return number_format($tot, 2, '.', '');
            }        
        } catch (\Throwable $th) {
            return $th;
        }
    }

