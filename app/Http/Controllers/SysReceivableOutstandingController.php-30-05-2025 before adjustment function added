            ->where(['is_main_account' => 1])->where(['credit_amount' => '0.00'])->update(['debit_amount' => $amount]);

            $temp_data=[];
            for ($i=0; $i < count($request->bi_amount); $i++) {
                if($request->bi_amount[$i] != 0){
                    $temp_data[]=[
